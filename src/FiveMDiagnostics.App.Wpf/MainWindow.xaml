<Window x:Class="FiveMDiagnostics.App.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FiveM Diagnostics"
        Height="980"
        Width="1620"
        MinHeight="860"
        MinWidth="1380"
        WindowStartupLocation="CenterScreen"
        Background="#14110F"
        FontFamily="Bahnschrift SemiCondensed">
    <Window.Resources>
        <SolidColorBrush x:Key="ShellBrush" Color="#14110F" />
        <SolidColorBrush x:Key="PanelBrush" Color="#211C1A" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#2E2723" />
        <SolidColorBrush x:Key="AccentBrush" Color="#E0A458" />
        <SolidColorBrush x:Key="AccentMutedBrush" Color="#6E9FA5" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F5EEDC" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#C5B9A5" />

        <Style TargetType="Border" x:Key="PanelStyle">
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="#3A302C" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Foreground" Value="#14110F" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#181412" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="#473C37" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Margin" Value="0,4,0,10" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background" Value="#181412" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="#473C37" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="24" CornerRadius="24" Margin="0,0,0,18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#E0A458" Offset="0" />
                    <GradientStop Color="#6E9FA5" Offset="0.55" />
                    <GradientStop Color="#14110F" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="FiveM Diagnostics" FontSize="34" FontWeight="Bold" Foreground="#14110F" />
                    <TextBlock Text="Local-first stutter diagnostics for FiveM with PresentMon, OBS, artifacts and deep capture." Foreground="#241C18" FontSize="16" Margin="0,6,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="State: " Foreground="#241C18" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SessionStateText}" Foreground="#241C18" />
                        <TextBlock Text="   Active process: " Foreground="#241C18" FontWeight="SemiBold" Margin="20,0,0,0" />
                        <TextBlock Text="{Binding ActiveProcessText}" Foreground="#241C18" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Background="#201915" CornerRadius="16" Padding="16" Width="360">
                    <StackPanel>
                        <TextBlock Text="Hotkeys" FontSize="20" FontWeight="Bold" />
                        <TextBlock Text="{Binding HotKeyLegend}" Foreground="#E6D8C0" TextWrapping="Wrap" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Controls" FontSize="22" FontWeight="Bold" />
                            <WrapPanel Margin="0,16,0,0">
                                <Button Content="Start Session" Command="{Binding StartSessionCommand}" />
                                <Button Content="Stop Session" Command="{Binding StopSessionCommand}" Background="#C97164" BorderBrush="#C97164" />
                                <Button Content="Mark Stutter" Command="{Binding MarkStutterCommand}" Background="#6E9FA5" BorderBrush="#6E9FA5" />
                                <Button Content="Mark Severe" Command="{Binding MarkSevereStutterCommand}" Background="#D96C47" BorderBrush="#D96C47" />
                                <Button Content="Export Latest" Command="{Binding ExportSelectedIncidentCommand}" />
                                <Button Content="Import Artifacts" Command="{Binding ImportArtifactsCommand}" Background="#A2B86C" BorderBrush="#A2B86C" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Session Settings" FontSize="22" FontWeight="Bold" />
                            <TextBlock Text="Server profile" Foreground="{StaticResource TextMutedBrush}" Margin="0,14,0,0" />
                            <TextBox Text="{Binding ServerProfileName, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Probe host / IP" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox Text="{Binding ProbeHost, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Endpoint hint (optional host:port)" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox Text="{Binding EndpointHint, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="PresentMon executable path" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox Text="{Binding PresentMonExecutablePath, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Working directory" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Export directory" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox Text="{Binding ExportDirectory, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="Artifact directory" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox Text="{Binding ArtifactDirectory, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Content="Include sensitive fields in export" IsChecked="{Binding IncludeSensitiveFields}" Margin="0,8,0,0" />
                            <CheckBox Content="Include attached artifacts in export" IsChecked="{Binding IncludeAttachedArtifacts}" />
                            <Button Content="Save Settings" Command="{Binding SaveSettingsCommand}" Width="180" Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelStyle}" Background="{StaticResource PanelAltBrush}">
                        <StackPanel>
                            <TextBlock Text="Fake Data Generator" FontSize="22" FontWeight="Bold" />
                            <TextBlock Text="Inject synthetic incidents to validate the rule engine without live FiveM, OBS or PresentMon." Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,14" TextWrapping="Wrap" />
                            <Button Content="Simulate OBS/GPU contention" Command="{Binding SimulateObsScenarioCommand}" />
                            <Button Content="Simulate FiveM resource spike" Command="{Binding SimulateResourceScenarioCommand}" Background="#A2B86C" BorderBrush="#A2B86C" />
                            <Button Content="Simulate network issue" Command="{Binding SimulateNetworkScenarioCommand}" Background="#6E9FA5" BorderBrush="#6E9FA5" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Status Log" FontSize="22" FontWeight="Bold" />
                            <ListView ItemsSource="{Binding StatusEntries}" Height="300" Margin="0,14,0,0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" Foreground="{StaticResource AccentBrush}" />
                                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Source}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="290" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource PanelStyle}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Recent Incidents" FontSize="22" FontWeight="Bold" Margin="0,0,0,14" />
                        <ListView ItemsSource="{Binding Incidents}" SelectedItem="{Binding SelectedIncident}" HorizontalContentAlignment="Stretch">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Marked" Width="150" DisplayMemberBinding="{Binding Marker.MarkedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" />
                                    <GridViewColumn Header="Severity" Width="110" DisplayMemberBinding="{Binding Marker.Severity}" />
                                    <GridViewColumn Header="Server" Width="110" DisplayMemberBinding="{Binding Environment.ServerProfileName}" />
                                    <GridViewColumn Header="Summary" Width="680" DisplayMemberBinding="{Binding Analysis.Summary}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource PanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="120" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Incident Summary" FontSize="22" FontWeight="Bold" />
                            <TextBox Grid.Row="1" Text="{Binding SelectedIncidentSummary}" Margin="0,14,0,18" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />

                            <TextBlock Grid.Row="2" Text="Ranked Hypotheses" FontSize="22" FontWeight="Bold" />
                            <ListView Grid.Row="3" ItemsSource="{Binding SelectedHypotheses}" Margin="0,14,0,0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#181412" BorderBrush="#473C37" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,10">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding Category}" FontSize="18" FontWeight="Bold" />
                                                    <TextBlock Text="{Binding Confidence, StringFormat={}{0:P0}}" Foreground="{StaticResource AccentBrush}" FontSize="18" HorizontalAlignment="Right" DockPanel.Dock="Right" />
                                                </DockPanel>
                                                <ItemsControl ItemsSource="{Binding Evidence}" Margin="0,10,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,0,0,6" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource PanelStyle}" Background="{StaticResource PanelAltBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Timeline" FontSize="22" FontWeight="Bold" />
                            <ListView Grid.Row="1" ItemsSource="{Binding SelectedTimeline}" Margin="0,14,0,0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#181412" BorderBrush="#473C37" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,10">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" />
                                                    <TextBlock Text="{Binding Category}" Foreground="{StaticResource AccentMutedBrush}" DockPanel.Dock="Right" />
                                                </DockPanel>
                                                <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" Margin="0,8,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
