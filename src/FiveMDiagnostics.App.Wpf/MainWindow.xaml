<Window x:Class="FiveMDiagnostics.App.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:props="clr-namespace:FiveMDiagnostics.App.Wpf.Properties"
        mc:Ignorable="d"
        Title="{x:Static props:Strings.AppTitle}"
        Height="920"
        Width="1500"
        MinHeight="720"
        MinWidth="1160"
        WindowStartupLocation="CenterScreen"
        Background="#0A1218"
        FontFamily="Bahnschrift SemiCondensed"
        Icon="AppIcon.ico">
    <Window.Resources>
        <SolidColorBrush x:Key="ShellBrush" Color="#0A1218" />
        <SolidColorBrush x:Key="PanelBrush" Color="#13202A" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#162736" />
        <SolidColorBrush x:Key="AccentBrush" Color="#7CD6C2" />
        <SolidColorBrush x:Key="AccentMutedBrush" Color="#D6A05B" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F4F8FB" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#9DB2C5" />

        <Style TargetType="Border" x:Key="PanelStyle">
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="#1E3343" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="TextBlock" x:Key="SubHeaderStyle">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource AccentMutedBrush}" />
            <Setter Property="Margin" Value="0,14,0,6" />
        </Style>

        <Style TargetType="TextBlock" x:Key="FieldHintStyle">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,-4,0,10" />
        </Style>

    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="24" CornerRadius="24" Margin="0,0,0,18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#12324A" Offset="0" />
                    <GradientStop Color="#1B5675" Offset="0.56" />
                    <GradientStop Color="#7CD6C2" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{x:Static props:Strings.AppTitle}" FontSize="34" FontWeight="Bold" Foreground="#F4F8FB" />
                    <TextBlock Text="{x:Static props:Strings.AppSubtitle}" Foreground="#DBE9F4" FontSize="16" Margin="0,6,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{x:Static props:Strings.StateLabel}" Foreground="#EAF4FB" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SessionStateText}" Foreground="#EAF4FB" Margin="4,0,0,0" />
                        <TextBlock Text="{x:Static props:Strings.ActiveProcessLabel}" Foreground="#EAF4FB" FontWeight="SemiBold" Margin="20,0,0,0" />
                        <TextBlock Text="{Binding ActiveProcessText}" Foreground="#EAF4FB" Margin="4,0,0,0" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Background="#0F1A22" CornerRadius="16" Padding="16" Width="360">
                    <StackPanel>
                        <TextBlock Text="{x:Static props:Strings.BasicModeHeader}" FontSize="20" FontWeight="Bold" />
                        <TextBlock Text="{x:Static props:Strings.BasicModeIntro}" Foreground="#DBE9F4" TextWrapping="Wrap" Margin="0,8,0,8" />
                        <TextBlock Text="{x:Static props:Strings.BasicModeStepOne}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Margin="0,4,0,0" />
                        <TextBlock Text="{x:Static props:Strings.BasicModeStepTwo}" Foreground="#DBE9F4" TextWrapping="Wrap" Margin="0,4,0,0" />
                        <TextBlock Text="{x:Static props:Strings.BasicModeStepThree}" Foreground="#DBE9F4" TextWrapping="Wrap" Margin="0,4,0,0" />
                        <TextBlock Text="{x:Static props:Strings.PresentMonStatusLabel}" Foreground="{StaticResource AccentMutedBrush}" FontWeight="SemiBold" Margin="0,12,0,0" />
                        <TextBlock Text="{Binding PresentMonStatusText}" Foreground="#DBE9F4" TextWrapping="Wrap" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly">
                <StackPanel>
                    <Border Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock Text="{x:Static props:Strings.ControlsHeader}" FontSize="22" FontWeight="Bold" />

                            <TextBlock Text="{x:Static props:Strings.SessionGroup}" Style="{StaticResource SubHeaderStyle}" />
                            <WrapPanel>
                                <Button Content="{x:Static props:Strings.StartSession}" Command="{Binding StartSessionCommand}" />
                                <Button Content="{x:Static props:Strings.StopSession}" Command="{Binding StopSessionCommand}" Background="#C97164" BorderBrush="#C97164" />
                            </WrapPanel>

                            <TextBlock Text="{x:Static props:Strings.IncidentActionsGroup}" Style="{StaticResource SubHeaderStyle}" />
                            <WrapPanel>
                                <Button Content="{x:Static props:Strings.MarkStutter}" Command="{Binding MarkStutterCommand}" Background="#6E9FA5" BorderBrush="#6E9FA5" />
                                <Button Content="{x:Static props:Strings.MarkSevere}" Command="{Binding MarkSevereStutterCommand}" Background="#D96C47" BorderBrush="#D96C47" />
                            </WrapPanel>

                            <Border Background="#10212C" BorderBrush="#2A4356" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,8,0,4">
                                <StackPanel>
                                    <TextBlock Text="{x:Static props:Strings.CaptureFeedbackHeader}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding CaptureFeedbackText}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="{x:Static props:Strings.DataGroup}" Style="{StaticResource SubHeaderStyle}" />
                            <WrapPanel>
                                <Button Content="{x:Static props:Strings.ExportLatest}" Command="{Binding ExportSelectedIncidentCommand}" />
                                <Button Content="{x:Static props:Strings.ImportArtifacts}" Command="{Binding ImportArtifactsCommand}" Background="#A2B86C" BorderBrush="#A2B86C" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock Text="{x:Static props:Strings.SettingsHeader}" FontSize="22" FontWeight="Bold" />

                            <Border Background="#0F1A22" BorderBrush="#254154" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,14,0,14">
                                <TextBlock Text="{x:Static props:Strings.SettingsIntro}" TextWrapping="Wrap" />
                            </Border>

                            <TextBlock Text="{x:Static props:Strings.ServerProfile}" Foreground="{StaticResource TextMutedBrush}" Margin="0,14,0,0" />
                            <TextBox Text="{Binding ServerProfileName, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{x:Static props:Strings.ServerProfileHint}" Style="{StaticResource FieldHintStyle}" />

                            <TextBlock Text="{x:Static props:Strings.LanguageLabel}" Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,0" />
                            <ComboBox ItemsSource="{Binding AvailableLanguages}" SelectedValue="{Binding SelectedLanguage}" SelectedValuePath="Code" DisplayMemberPath="DisplayName" Margin="0,4,0,4" MinWidth="240" HorizontalAlignment="Stretch" />
                            <TextBlock Text="{x:Static props:Strings.LanguageChangeHint}" Style="{StaticResource FieldHintStyle}" FontStyle="Italic" />

                            <Expander Header="{x:Static props:Strings.NetworkHintsHeader}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,6,0,0">
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="{x:Static props:Strings.NetworkHintsDescription}" Style="{StaticResource FieldHintStyle}" Margin="0,0,0,8" />

                                    <TextBlock Text="{x:Static props:Strings.ProbeHost}" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBox Text="{Binding ProbeHost, UpdateSourceTrigger=PropertyChanged}" ToolTip="{x:Static props:Strings.ProbeHostHint}" />
                                    <TextBlock Text="{x:Static props:Strings.ProbeHostHint}" Style="{StaticResource FieldHintStyle}" />

                                    <TextBlock Text="{x:Static props:Strings.EndpointHint}" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBox Text="{Binding EndpointHint, UpdateSourceTrigger=PropertyChanged}" ToolTip="{x:Static props:Strings.EndpointHintDescription}" />
                                    <TextBlock Text="{x:Static props:Strings.EndpointHintDescription}" Style="{StaticResource FieldHintStyle}" />
                                </StackPanel>
                            </Expander>

                            <Expander Header="{x:Static props:Strings.AdvancedSettings}" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,0">
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="{x:Static props:Strings.AdvancedSettingsDescription}" Style="{StaticResource FieldHintStyle}" Margin="0,0,0,8" />
                                    <TextBlock Text="{x:Static props:Strings.PresentMonPath}" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBox Text="{Binding PresentMonExecutablePath, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{x:Static props:Strings.WorkingDirectory}" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBox Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{x:Static props:Strings.ExportDirectory}" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBox Text="{Binding ExportDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock Text="{x:Static props:Strings.ArtifactDirectory}" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBox Text="{Binding ArtifactDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Expander>

                            <CheckBox Content="{x:Static props:Strings.IncludeSensitiveFields}" IsChecked="{Binding IncludeSensitiveFields}" Margin="0,12,0,0" />
                            <CheckBox Content="{x:Static props:Strings.IncludeAttachedArtifacts}" IsChecked="{Binding IncludeAttachedArtifacts}" />
                            <Button Content="{x:Static props:Strings.SaveSettings}" Command="{Binding SaveSettingsCommand}" Width="180" Margin="0,10,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelStyle}" Background="{StaticResource PanelAltBrush}">
                        <Expander Foreground="{StaticResource TextPrimaryBrush}" IsExpanded="False">
                            <Expander.Header>
                                <TextBlock Text="{x:Static props:Strings.FakeDataHeader}" FontSize="22" FontWeight="Bold" />
                            </Expander.Header>
                            <StackPanel Margin="0,14,0,0">
                                <TextBlock Text="{x:Static props:Strings.FakeDataDescription}" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,14" TextWrapping="Wrap" />
                                <Button Content="{x:Static props:Strings.SimulateObs}" Command="{Binding SimulateObsScenarioCommand}" />
                                <Button Content="{x:Static props:Strings.SimulateResource}" Command="{Binding SimulateResourceScenarioCommand}" Background="#A2B86C" BorderBrush="#A2B86C" />
                                <Button Content="{x:Static props:Strings.SimulateNetwork}" Command="{Binding SimulateNetworkScenarioCommand}" Background="#6E9FA5" BorderBrush="#6E9FA5" />
                            </StackPanel>
                        </Expander>
                    </Border>

                    <Border Style="{StaticResource PanelStyle}">
                        <Expander Foreground="{StaticResource TextPrimaryBrush}" IsExpanded="False">
                            <Expander.Header>
                                <TextBlock Text="{x:Static props:Strings.StatusLogHeader}" FontSize="22" FontWeight="Bold" />
                            </Expander.Header>
                            <ListView ItemsSource="{Binding StatusEntries}" Height="220" Margin="0,14,0,0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" Foreground="{StaticResource AccentBrush}" />
                                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Source}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Expander>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="290" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource PanelStyle}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="{x:Static props:Strings.RecentIncidentsHeader}" FontSize="22" FontWeight="Bold" Margin="0,0,0,14" />
                        <ListView ItemsSource="{Binding Incidents}" SelectedItem="{Binding SelectedIncident}" HorizontalContentAlignment="Stretch" ItemContainerStyle="{StaticResource GridViewItemStyle}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="{x:Static props:Strings.MarkedColumn}" Width="150" DisplayMemberBinding="{Binding Marker.MarkedAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" />
                                    <GridViewColumn Header="{x:Static props:Strings.SeverityColumn}" Width="110" DisplayMemberBinding="{Binding Marker.Severity}" />
                                    <GridViewColumn Header="{x:Static props:Strings.ServerColumn}" Width="110" DisplayMemberBinding="{Binding Environment.ServerProfileName}" />
                                    <GridViewColumn Header="{x:Static props:Strings.SummaryColumn}" Width="680" DisplayMemberBinding="{Binding Analysis.Summary}" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </DockPanel>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource PanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="120" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="{x:Static props:Strings.IncidentSummaryHeader}" FontSize="22" FontWeight="Bold" />
                            <TextBox Grid.Row="1" Text="{Binding SelectedIncidentSummary, Mode=OneWay}" Margin="0,14,0,18" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />

                            <TextBlock Grid.Row="2" Text="{x:Static props:Strings.RankedHypothesesHeader}" FontSize="22" FontWeight="Bold" />
                            <ListView Grid.Row="3" ItemsSource="{Binding SelectedHypotheses}" Margin="0,14,0,0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#0F1B24" BorderBrush="#284052" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,10">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding Category}" FontSize="18" FontWeight="Bold" />
                                                    <TextBlock Text="{Binding Confidence, StringFormat={}{0:P0}}" Foreground="{StaticResource AccentBrush}" FontSize="18" HorizontalAlignment="Right" DockPanel.Dock="Right" />
                                                </DockPanel>
                                                <ItemsControl ItemsSource="{Binding Evidence}" Margin="0,10,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,0,0,6" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource PanelStyle}" Background="{StaticResource PanelAltBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="{x:Static props:Strings.TimelineHeader}" FontSize="22" FontWeight="Bold" />
                            <ListView Grid.Row="1" ItemsSource="{Binding SelectedTimeline}" Margin="0,14,0,0">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#0F1B24" BorderBrush="#284052" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,10">
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" />
                                                    <TextBlock Text="{Binding Category}" Foreground="{StaticResource AccentMutedBrush}" DockPanel.Dock="Right" />
                                                </DockPanel>
                                                <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" Margin="0,8,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
